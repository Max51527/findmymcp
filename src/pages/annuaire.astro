---
import BaseLayout from '../layouts/BaseLayout.astro';
import MCPCard from '../components/MCPCard.astro';
import { allMCPs, allCategories } from '../lib/mcps';

const langs = [...new Set(allMCPs.map((m) => m.langage))].sort();
const compats = [...new Set(allMCPs.flatMap((m) => m.compatible_avec))].sort();
const initialMCPs = [...allMCPs].sort((a, b) => b.github_stars - a.github_stars);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Annuaire complet des MCP servers',
  url: 'https://findmymcp.fr/annuaire',
  description: `${allMCPs.length} MCP servers indexés et classés.`,
};
---

<BaseLayout
  title="Annuaire complet des MCP servers"
  description={`Liste filtrable de ${allMCPs.length} MCP servers (Model Context Protocol) compatibles Claude. Filtrer par catégorie, langage, licence, compatibilité.`}
  schema={schema}
>
  <section class="container-wide py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">Annuaire complet</h1>
    <p class="text-slate-300 mb-8 max-w-2xl">
      {allMCPs.length} MCP servers classés. Utilisez les filtres pour trouver celui qui correspond à votre usage.
    </p>

    <div x-data={`{
      q: '',
      cats: [],
      langs: [],
      compats: [],
      sort: 'stars',
      get filtered() {
        let items = window.__MCPS__ ?? [];
        if (this.q) {
          const q = this.q.toLowerCase();
          items = items.filter(m =>
            m.nom.toLowerCase().includes(q) ||
            m.description_fr.toLowerCase().includes(q) ||
            (m.tags || []).some(t => t.toLowerCase().includes(q))
          );
        }
        if (this.cats.length) items = items.filter(m => m.categorie.some(c => this.cats.includes(c)));
        if (this.langs.length) items = items.filter(m => this.langs.includes(m.langage));
        if (this.compats.length) items = items.filter(m => m.compatible_avec.some(c => this.compats.includes(c)));
        if (this.sort === 'stars') items = [...items].sort((a,b) => b.github_stars - a.github_stars);
        if (this.sort === 'date') items = [...items].sort((a,b) => b.date_ajout.localeCompare(a.date_ajout));
        if (this.sort === 'name') items = [...items].sort((a,b) => a.nom.localeCompare(b.nom));
        return items;
      },
      reset() { this.q=''; this.cats=[]; this.langs=[]; this.compats=[]; this.sort='stars'; }
    }`}>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 mb-8">
        <input
          type="search"
          placeholder="Rechercher (nom, description, tag)…"
          x-model="q"
          class="lg:col-span-2 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-accent-500 focus:outline-none"
        />

        <select x-model="sort" class="rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm">
          <option value="stars">Tri : ★ stars</option>
          <option value="date">Tri : date d'ajout</option>
          <option value="name">Tri : alphabétique</option>
        </select>

        <button @click="reset()" class="btn-ghost">Réinitialiser</button>
      </div>

      <details class="mb-8 rounded-lg border border-slate-800 bg-slate-900/50 p-4">
        <summary class="cursor-pointer font-semibold text-slate-200">Filtres avancés</summary>

        <div class="mt-4 grid gap-6 md:grid-cols-3">
          <div>
            <div class="text-sm font-semibold text-slate-300 mb-2">Catégorie</div>
            <div class="space-y-1.5 max-h-48 overflow-y-auto pr-2">
              {allCategories.map((c) => (
                <label class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-200">
                  <input type="checkbox" :value={`'${c.slug}'`} x-model="cats" class="rounded border-slate-600 bg-slate-800" />
                  {c.nom}
                </label>
              ))}
            </div>
          </div>

          <div>
            <div class="text-sm font-semibold text-slate-300 mb-2">Langage</div>
            <div class="space-y-1.5">
              {langs.map((l) => (
                <label class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-200">
                  <input type="checkbox" :value={`'${l}'`} x-model="langs" class="rounded border-slate-600 bg-slate-800" />
                  {l}
                </label>
              ))}
            </div>
          </div>

          <div>
            <div class="text-sm font-semibold text-slate-300 mb-2">Compatibilité</div>
            <div class="space-y-1.5">
              {compats.map((c) => (
                <label class="flex items-center gap-2 text-sm text-slate-400 hover:text-slate-200">
                  <input type="checkbox" :value={`'${c}'`} x-model="compats" class="rounded border-slate-600 bg-slate-800" />
                  {c}
                </label>
              ))}
            </div>
          </div>
        </div>
      </details>

      <p class="text-sm text-slate-400 mb-4" x-text="`${filtered.length} résultat${filtered.length > 1 ? 's' : ''}`"></p>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <template x-for="mcp in filtered" :key="mcp.slug">
          <a
            :href="`/mcp/${mcp.slug}`"
            class="group flex flex-col rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition-colors hover:border-accent-500"
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <h3 class="font-semibold text-slate-100 group-hover:text-accent-400" x-text="mcp.nom"></h3>
              <div class="flex shrink-0 gap-1.5 text-xs">
                <span x-show="mcp.featured" class="rounded-full bg-accent-500/20 px-2 py-0.5 font-medium text-accent-400">★</span>
                <span x-show="mcp.sponsored" class="rounded-full bg-amber-500/20 px-2 py-0.5 font-medium text-amber-400">Sponso</span>
                <span x-show="mcp.verified" class="rounded-full bg-emerald-500/20 px-2 py-0.5 font-medium text-emerald-400">✓</span>
              </div>
            </div>
            <p class="text-sm text-slate-400 leading-relaxed line-clamp-3 mb-4 flex-1" x-text="mcp.description_fr"></p>
            <div class="flex items-center justify-between text-xs text-slate-500 pt-3 border-t border-slate-800">
              <span class="font-mono" x-text="mcp.langage"></span>
              <span class="font-mono" x-text="mcp.licence"></span>
            </div>
          </a>
        </template>
      </div>

      <div x-show="filtered.length === 0" class="rounded-lg border border-dashed border-slate-700 p-12 text-center text-slate-400">
        Aucun résultat. Essayez d'autres filtres ou
        <a href="/soumettre" class="text-accent-400 hover:underline">proposez un nouveau MCP</a>.
      </div>
    </div>

    <script
      is:inline
      define:vars={{ mcps: initialMCPs }}
    >
      window.__MCPS__ = mcps;
    </script>
    <script>
      import Alpine from 'alpinejs';
      Alpine.start();
    </script>
  </section>
</BaseLayout>
