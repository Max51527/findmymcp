---
import BaseLayout from '../layouts/BaseLayout.astro';
import { allCategories } from '../lib/mcps';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<BaseLayout
  title="Soumettre un MCP server"
  description="Proposez un nouveau MCP server à l'annuaire FindMyMCP. Validation manuelle sous 7 jours, gratuit."
>
  <section class="container-prose py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">Soumettre un MCP server</h1>
    <p class="text-slate-300 mb-8">
      Vous avez créé ou utilisé un MCP qui n'est pas encore dans l'annuaire ?
      Remplissez le formulaire ci-dessous. Nous validons sous 7 jours.
    </p>

    <form id="submit-form" class="space-y-5 rounded-xl border border-slate-800 bg-slate-900/50 p-6">
      <div>
        <label for="nom" class="block text-sm font-medium text-slate-200 mb-1.5">Nom du MCP *</label>
        <input
          type="text"
          id="nom"
          name="nom"
          required
          maxlength="100"
          placeholder="Ex: Linear MCP Server"
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 focus:border-accent-500 focus:outline-none"
        />
      </div>

      <div>
        <label for="github_url" class="block text-sm font-medium text-slate-200 mb-1.5">URL GitHub *</label>
        <input
          type="url"
          id="github_url"
          name="github_url"
          required
          pattern="https://github\.com/.+"
          placeholder="https://github.com/auteur/repo"
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 focus:border-accent-500 focus:outline-none"
        />
      </div>

      <div>
        <label for="categorie" class="block text-sm font-medium text-slate-200 mb-1.5">Catégorie principale *</label>
        <select
          id="categorie"
          name="categorie"
          required
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 focus:border-accent-500 focus:outline-none"
        >
          <option value="">— Choisir —</option>
          {allCategories.map((c) => <option value={c.slug}>{c.nom}</option>)}
        </select>
      </div>

      <div>
        <label for="description_courte" class="block text-sm font-medium text-slate-200 mb-1.5">
          Description courte * <span class="text-xs text-slate-500">(max 200 chars, en FR)</span>
        </label>
        <textarea
          id="description_courte"
          name="description_courte"
          required
          maxlength="200"
          rows="3"
          placeholder="Phrase claire de 1-2 lignes décrivant ce que fait le MCP."
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 focus:border-accent-500 focus:outline-none"
        ></textarea>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-200 mb-1.5">Votre email *</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="vous@exemple.fr"
          class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 focus:border-accent-500 focus:outline-none"
        />
        <p class="text-xs text-slate-500 mt-1">Utilisé uniquement pour vous notifier de la validation. Jamais publié.</p>
      </div>

      <div class="flex items-start gap-2">
        <input type="checkbox" id="rgpd" name="rgpd" required class="mt-1 rounded border-slate-600 bg-slate-800" />
        <label for="rgpd" class="text-sm text-slate-300">
          J'accepte que mon email soit utilisé uniquement pour me notifier du statut de cette soumission.
          Voir <a href="/confidentialite" class="text-accent-400 hover:underline">Politique de confidentialité</a>.
        </label>
      </div>

      <div id="turnstile-container" class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>

      <button type="submit" class="btn-primary w-full justify-center">
        Soumettre la proposition →
      </button>

      <div id="form-status" class="text-sm hidden"></div>
    </form>

    <details class="mt-8 rounded-lg border border-slate-800 bg-slate-900/50 p-4 text-sm text-slate-300">
      <summary class="cursor-pointer font-semibold">Que se passe-t-il après soumission ?</summary>
      <ol class="mt-3 ml-5 list-decimal space-y-2">
        <li>Une issue est créée automatiquement sur notre repo GitHub.</li>
        <li>Le scraper enrichit la fiche (stars, langage, README) en quelques heures.</li>
        <li>Un humain vérifie la cohérence et la cloison éditoriale.</li>
        <li>Si OK, la fiche apparaît sur l'annuaire sous 7 jours et vous recevez un email.</li>
      </ol>
    </details>

    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline>
      document.getElementById('submit-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const status = document.getElementById('form-status');
        const data = Object.fromEntries(new FormData(form));
        status.classList.remove('hidden');
        status.textContent = 'Envoi en cours…';
        status.className = 'text-sm text-slate-400';

        try {
          const res = await fetch('/api/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (res.ok) {
            status.textContent = '✓ Soumission reçue. Vous recevrez un email de confirmation sous peu.';
            status.className = 'text-sm text-emerald-400';
            form.reset();
          } else {
            const err = await res.text();
            status.textContent = `Erreur : ${err || 'soumission refusée'}`;
            status.className = 'text-sm text-red-400';
          }
        } catch (err) {
          status.textContent = 'Erreur réseau. Réessayez dans quelques minutes.';
          status.className = 'text-sm text-red-400';
        }
      });
    </script>
  </section>
</BaseLayout>
