---
const { pathname } = Astro.url;
const isActive = (path: string) => pathname === path || pathname.startsWith(path + '/');
---

<header class="border-b border-slate-800 bg-slate-950/80 backdrop-blur sticky top-0 z-40">
  <div class="container-wide flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-bold text-lg">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent-500 text-white">
        🔍
      </span>
      <span>FindMyMCP<span class="text-accent-400">.fr</span></span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      <a
        href="/annuaire"
        class={`hover:text-accent-400 ${isActive('/annuaire') ? 'text-accent-400' : 'text-slate-300'}`}
      >
        Annuaire
      </a>
      <a
        href="/a-propos"
        class={`hover:text-accent-400 ${isActive('/a-propos') ? 'text-accent-400' : 'text-slate-300'}`}
      >
        À propos
      </a>
      <a href="/soumettre" class="btn-primary">
        + Soumettre un MCP
      </a>
    </nav>

    <button
      class="md:hidden text-slate-300"
      aria-label="Menu"
      onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800 px-4 py-3 space-y-2">
    <a href="/annuaire" class="block py-2 text-slate-300 hover:text-accent-400">Annuaire</a>
    <a href="/a-propos" class="block py-2 text-slate-300 hover:text-accent-400">À propos</a>
    <a href="/soumettre" class="block py-2 text-accent-400">+ Soumettre un MCP</a>
  </div>
</header>
