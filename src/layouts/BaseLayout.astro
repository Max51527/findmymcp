---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  schema?: object;
}

const {
  title,
  description = 'Annuaire francophone des MCP servers (Model Context Protocol) pour Claude et autres LLM compatibles. Gratuit, sans pub intrusive.',
  image = '/og-default.svg',
  noIndex = false,
  schema,
} = Astro.props;

const siteUrl = 'https://findmymcp.fr';
const canonical = new URL(Astro.url.pathname, siteUrl).toString().replace(/\/$/, '') || siteUrl;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

const fullTitle = title.endsWith('FindMyMCP') ? title : `${title} — FindMyMCP`;

const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="fr-FR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="FindMyMCP" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="FindMyMCP — derniers MCP" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {schema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    )}
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </body>
</html>
